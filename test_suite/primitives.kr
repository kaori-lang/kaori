/* test primitive vars. & operations */

fun test_numbers() {
    let a = 10.0;
    let b = -2.0;

    // test arithmetic
    let sum_a_b = a + b;
    let diff_a_b = a - b;
    let prod_a_b = a * b;
    let quot_a_b = a / b;

    if sum_a_b != 8.0 {
        return false;
    }

    if diff_a_b != 12.0 {
        return false;
    }

    if prod_a_b != -20.0 {
        return false;
    }

    if quot_a_b != -5.0 {
        return false;
    }

    return true;
}

fun test_newton() {
    /* approximate magnitude of the 2-D vector of <x, y> using Newton's Method */
    let x = 8.0;
    let y = 4.0;

    let dist_squ = x * x + y * y;
    let guess = 7.25;

    for let iter = 0; iter < 4; iter += 1 {
        guess = 0.5 * (guess + dist_squ / guess);
    }

    /* max allowed error in magnitude approximation */
    let max_elipson = 0.01;

    /* expected answer: D_target = sqrt(80) */
    let target_answer = 8.944;

    print(guess);
    print(target_answer);

    return (target_answer - guess) < max_elipson;
}

fun main() {
    /* test arithmetic: 1 is an error */
    if not test_numbers() {
        print(1);
    }

    /* test complex arithmetic: 1 is an error */
    if not test_newton() {
        print(1);
    }
}